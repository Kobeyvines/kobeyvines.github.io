---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const allBlogPosts = await getCollection('blog');

// Filter featured projects
const featuredProjects = allProjects.filter(p => p.data.featured).slice(0, 3);

// Sort blog posts by date and take the latest 3
// We name this latestPosts to match the reference in your HTML below
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const techStack = ["Python", "AWS", "FastAPI", "Scikit-Learn", "Pandas", "PostgreSQL", "TensorFlow"];
---

<Layout title="Brian Kuria | Data Scientist & Cloud Architect" description="AWS Certified Solutions Architect and Data Scientist specialized in predictive modeling and scalable infrastructure.">
  
  <div class="w-full flex flex-col items-center">
    
    {/* Hero Section */}
    <section class="w-full max-w-6xl mx-auto px-4 py-24 md:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          <span class="text-[10px] font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">Available for Opportunities</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 dark:text-white mb-6 tracking-tight leading-tight text-left">
          Solving complex problems with <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">Data & Cloud.</span>
        </h1>
        
        <p class="text-xl text-slate-600 dark:text-slate-400 mb-10 leading-relaxed text-left">
          I’m <span class="text-slate-900 dark:text-white font-semibold">Brian Kuria</span>, an AWS Certified Solutions Architect and Data Scientist. I build intelligent systems that don't just predict the future, but scale to meet it.
        </p>
        
        <div class="flex flex-wrap gap-4 justify-start">
          <a href="/projects" class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-8 py-4 rounded-xl hover:opacity-90 transition-all font-bold shadow-lg shadow-blue-500/10">
            Explore My Work
          </a>
          <a href="/contact" class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white border border-slate-200 dark:border-slate-800 px-8 py-4 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all font-bold">
            Get in Touch
          </a>
        </div>

        <div class="mt-16 flex flex-wrap gap-3 items-center opacity-60">
          <span class="text-xs font-bold uppercase tracking-widest text-slate-500">Core Stack:</span>
          {techStack.map(tech => (
            <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded border border-slate-200 dark:border-slate-700">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    {/* Featured Projects Section */}
    <section class="w-full bg-slate-50/50 dark:bg-slate-900/30 py-24 border-y border-slate-100 dark:border-slate-800 overflow-hidden">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex justify-between items-end mb-12">
          <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 tracking-tight">Selected Projects</h2>
            <p class="text-slate-600 dark:text-slate-400">Deployed models and cloud architecture case studies.</p>
          </div>
          <a href="/projects" class="hidden md:block text-sm font-bold text-blue-600 dark:text-blue-400 hover:translate-x-1 transition-transform">
            View all projects →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
          {featuredProjects.map(project => (
            <ProjectCard 
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            link={project.data.link}
            github={project.data.github}
            tags={project.data.tags}
            isFeatured={project.data.isFeatured}
            /* ADD THIS LINE */
            status={project.data.status} 
          />
          ))}
        </div>
      </div>
    </section>

    {/* Recent Blog Posts */}
    <section class="w-full max-w-6xl mx-auto px-4 pt-24 pb-32 clear-both">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 tracking-tight">Latest Insights</h2>
          <p class="text-slate-600 dark:text-slate-400">Deep dives into Data Science, Python engineering, and AWS.</p>
        </div>
        <a href="/blog" class="hidden md:block text-sm font-bold text-blue-600 dark:text-blue-400 hover:translate-x-1 transition-transform">
          Read the blog →
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full">
        {latestPosts.map((post) => (
          <BlogPostCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            readingTime={post.data.readingTime} 
          />
        ))}
      </div>
    </section>
    
  </div>
</Layout>