---
import Layout from './Layout.astro';
import Comments from '../components/Comments.astro'; // Import your new component

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readingTime?: string;
}

const { title, description, date, tags = [], readingTime = "5 min read" } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<Layout title={`${title} | Brian Kuria`} description={description}>
  <main class="w-full font-sans">
    <div class="w-full bg-gradient-to-b from-slate-50 dark:from-slate-900/50 to-transparent">
      <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
        <header class="text-center"> 
          <div class="flex items-center justify-center gap-3 text-xs font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-8 font-sans">
             <time datetime={date.toISOString()}>{formattedDate}</time>
             <span class="w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-600"></span>
             <span>{readingTime}</span>
          </div>

          <h1 class="text-4xl sm:text-6xl font-extrabold text-slate-900 dark:text-white mb-8 leading-[1.1] tracking-tight">
            {title}
          </h1>
          
          <p class="text-xl sm:text-2xl text-slate-500 dark:text-slate-400 leading-relaxed max-w-2xl mx-auto italic">
            {description}
          </p>
        </header>
      </article>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <article class="prose prose-slate dark:prose-invert max-w-none 
        font-serif text-lg
        prose-headings:font-sans prose-headings:tracking-tight
        prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-6
        prose-p:leading-9 prose-p:mb-8 prose-p:text-slate-800 dark:prose-p:text-slate-200
        prose-img:rounded-xl prose-img:shadow-2xl prose-img:mx-auto
        prose-pre:rounded-2xl prose-pre:shadow-inner prose-pre:bg-slate-900
        prose-blockquote:text-2xl prose-blockquote:font-serif prose-blockquote:text-slate-500">
        <slot />
      </article>

      <footer class="mt-20 pt-12 border-t border-slate-200 dark:border-slate-800 pb-24">
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">
            Discussion
          </h2>
          <p class="text-slate-500 dark:text-slate-400 mt-2 text-sm">
            Have a question or a thought on this analysis? Leave a comment below via GitHub.
          </p>
        </div>
        
        <Comments />
      </footer>
      </div>
  </main>
</Layout>