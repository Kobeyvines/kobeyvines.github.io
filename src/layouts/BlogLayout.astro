---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<Layout title={title} description={description}>
  <Header currentPath="/blog" />
  <main class="max-w-3xl mx-auto px-4 py-12">
    <article class="prose dark:prose-invert max-w-none">
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
          {title}
        </h1>
        <p class="text-slate-600 dark:text-slate-400 mb-4">
          {description}
        </p>
        <time class="text-sm text-slate-500 dark:text-slate-400">
          {formattedDate}
        </time>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map(tag => (
              <span class="text-xs bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>
      <div class="prose dark:prose-invert max-w-none">
        <slot />
      </div>
    </article>
    <hr class="my-12 border-slate-300 dark:border-slate-700" />
    <a href="/blog" class="text-blue-600 dark:text-blue-400 hover:underline">
      ← Back to Blog
    </a>
  </main>
  <Footer />
</Layout>
