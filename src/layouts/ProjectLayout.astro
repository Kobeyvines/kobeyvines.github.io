---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  link?: string;
  github?: string;
  tags?: string[];
}

const { title, description, image, link, github, tags = [] } = Astro.props;
---

<Layout title={title} description={description}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <article>
      <header class="mb-8">
        {image && (
          <img src={image} alt={title} class="w-full h-96 object-cover rounded-lg mb-6" />
        )}
        <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">
          {title}
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">
          {description}
        </p>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map(tag => (
              <span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        )}
        <div class="flex gap-4">
          {link && (
            <a href={link} target="_blank" rel="noopener noreferrer" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">
              View Project
            </a>
          )}
          {github && (
            <a href={github} target="_blank" rel="noopener noreferrer" class="bg-slate-800 text-white px-4 py-2 rounded hover:bg-slate-900 transition">
              View on GitHub
            </a>
          )}
        </div>
      </header>
      <div class="prose dark:prose-invert max-w-none mb-8">
        <slot />
      </div>
    </article>
    <hr class="my-12 border-slate-300 dark:border-slate-700" />
    <a href="/projects" class="text-blue-600 dark:text-blue-400 hover:underline">
      ← Back to Projects
    </a>
  </main>
</Layout>
