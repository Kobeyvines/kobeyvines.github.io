---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = 'Brian Kuria | Cloud & Data Science', 
  description = 'Portfolio of Brian Kuria, an AWS Certified Solutions Architect and Data Scientist.',
  image = '/og-image.png' 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>

    {/* SINGLE THEME SCRIPT: Consolidate and place at the end of head */}
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        // If you want strictly Light by default even if the user has Dark OS settings,
        // return 'light' here. If you want to follow OS, keep matchMedia.
        return 'light'; 
      };

      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList.toggle('dark', isDark);

      if (typeof localStorage !== 'undefined') {
        // Watch for changes to the 'dark' class and update localStorage
        const observer = new MutationObserver(() => {
          const isDarkNow = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDarkNow ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col w-full overflow-x-hidden bg-slate-50 dark:bg-[#050505] text-slate-900 dark:text-slate-100 selection:bg-blue-100 dark:selection:bg-blue-900/30 transition-colors duration-300 font-sans">
    <Header currentPath={Astro.url.pathname} />
    <main class="flex-grow w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* Keep your existing global styles here */
  :root {
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-serif: 'Lora', Georgia, serif;
  }

  body {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
  }

  /* ... rest of your scrollbar and table logic ... */
</style>