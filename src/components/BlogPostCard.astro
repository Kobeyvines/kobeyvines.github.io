---
interface Props {
  title: string;
  description: string;
  date: Date;
  id: string;
  tags?: string[];
}

const { title, description, date, id, tags = [] } = Astro.props;
const slug = id.replace(/\.md$/, '');

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<div class="bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition-shadow p-6">
  <div class="flex justify-between items-start mb-3">
    <a href={`/blog/${slug}`} class="text-xl font-semibold text-slate-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400">
      {title}
    </a>
    <time class="text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap ml-2">
      {formattedDate}
    </time>
  </div>
  <p class="text-slate-600 dark:text-slate-400 mb-4">
    {description}
  </p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map(tag => (
        <span class="text-xs bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 px-2 py-1 rounded">
          {tag}
        </span>
      ))}
    </div>
  )}
  <a href={`/blog/${slug}`} class="text-blue-600 dark:text-blue-400 hover:underline text-sm font-medium">
    Read More →
  </a>
</div>
