---
interface Props {
  title: string;
  description: string;
  date: Date;
  id: string;
  tags?: string[];
  readingTime?: string;
}

const { title, description, date, id, tags = [], readingTime = "5 min read" } = Astro.props;

// For Astro 5 loaders, the id is usually the filename or a unique string
const slug = id.split('/').pop()?.replace(/\.(md|mdx)$/, '') || id;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="group cursor-pointer">
  <article class="flex flex-col h-full bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 p-6 sm:p-7 shadow-sm hover:shadow-lg transition-all duration-300">
    <div class="flex flex-col gap-3 flex-grow">
      <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-600"></span>
        <span class="text-blue-600 dark:text-blue-400">{readingTime}</span>
      </div>

      <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
        {title}
      </h3>

      <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 leading-relaxed">
        {description}
      </p>
    </div>

    <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800">
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.slice(0, 2).map(tag => (
            <span class="text-xs font-medium text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 px-2.5 py-1 rounded-full">
              {tag.toLowerCase()}
            </span>
          ))}
          {tags.length > 2 && (
            <span class="text-xs text-slate-500 dark:text-slate-400">+{tags.length - 2}</span>
          )}
        </div>
      )}
      
      <div class="flex items-center gap-2 text-sm font-semibold text-blue-600 dark:text-blue-400 group-hover:gap-3 transition-all">
        <span>Read article</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>
    </div>
  </article>
</a>