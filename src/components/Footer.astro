---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/kobeyvines', icon: 'i-ph-github-logo' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/brian-irungu-5476ba270/', icon: 'i-ph-linkedin-logo' },
  { label: 'Medium', href: 'https://medium.com/@kobeyvines', icon: 'i-ph-medium-logo' },
];
---

<footer class="w-full bg-slate-50 dark:bg-slate-950 mt-20 py-16 border-t border-slate-200 dark:border-slate-800 transition-colors">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 mb-12">
      
      <div class="md:col-span-1">
        <h3 class="font-bold text-slate-900 dark:text-white mb-4 tracking-tight text-lg">Brian Kuria</h3>
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
          IT Professional & Data Scientist specializing in AWS infrastructure and predictive modeling.
        </p>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest font-bold text-slate-400 dark:text-slate-500 mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400 font-medium">
          <li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Blog</a></li>
          <li><a href="/projects" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Projects</a></li>
          <li><a href="/about" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">About</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest font-bold text-slate-400 dark:text-slate-500 mb-4">Connect</h3>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400 font-medium">
          {socialLinks.map(link => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center gap-2">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm self-start">
        <h3 class="text-xs uppercase tracking-widest font-bold text-blue-600 dark:text-blue-400 mb-3 flex items-center gap-2">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Status
        </h3>
        <p class="text-xs text-slate-600 dark:text-slate-400 leading-normal">
          Currently optimizing SVD models and open to <strong>Junior Python/Data Engineering</strong> roles.
        </p>
      </div>

    </div>

    <div class="pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
      <p class="text-xs text-slate-500 dark:text-slate-500">
        &copy; {currentYear} Brian Kuria.
      </p>
      <div class="flex gap-4 text-[10px] font-mono text-slate-400">
        <span> Nairobi, KE </span>
      </div>
    </div>
  </div>
</footer>